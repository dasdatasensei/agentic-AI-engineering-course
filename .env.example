# ── LLM: Gemini (synthesis + embeddings) ───────────────────────────────────
# Free tier, no credit card — https://aistudio.google.com
GOOGLE_API_KEY=

# ── LLM: Groq (routing + classification) ───────────────────────────────────
# Free tier, no credit card — https://console.groq.com
GROQ_API_KEY=

# ── Web Search ──────────────────────────────────────────────────────────────
# Free tier, 1,000 credits/month — https://app.tavily.com
# DuckDuckGo fallback requires no key — used automatically when credits run out
TAVILY_API_KEY=

# ── Observability ───────────────────────────────────────────────────────────
# Free tier, 5,000 traces/month — https://smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=era-platform-course
LANGCHAIN_TRACING_V2=true
MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# ── Local services (Section 6+) ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── API auth (Section 8+) — generate your own, never commit real secrets ───
JWT_SECRET_KEY=

# ── Vector store ─────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ── Production-only (see docs/production.md) — leave blank for course work ──
# ANTHROPIC_API_KEY=
# PINECONE_API_KEY=
# COHERE_API_KEY=
# E2B_API_KEY=
